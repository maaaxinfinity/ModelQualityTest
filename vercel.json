{
  "functions": {
    "api/run-test.js": {
      "maxDuration": 300
    },
    "api/admin/prices.js": {
      "maxDuration": 300
    },
    "api/cron/sync.js": {
      "maxDuration": 300
    },
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 2 * * *"
    }
  ]
}
